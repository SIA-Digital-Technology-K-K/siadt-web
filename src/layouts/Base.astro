---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description = 'ＳＩＡデジタルテクノロジー株式会社は、AI・ビッグデータ・IoTなど最先端の技術を活用し、日本の伝統を守りながら日本の未来を創るデジタルソリューションを提供します。',
  lang = 'ja',
  ogImage = '/images/hero-robot-girl.webp',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);

const navProducts = [
  { href: '/製品情報/', label: '製品情報' },
  { href: 'https://engawa-app.jp/', label: '緣側', external: true },
  { href: 'https://livein-japan.jp', label: '日本通', external: true },
  { href: 'https://siadt-video-studio.web.app/', label: 'SIA-studio', external: true },
  { href: '/ハードウェア製品/', label: 'AIエッジ計算製品' },
  { href: '/人工知能アシスタント/', label: 'AIアシスタント' },
];
const navCompany = [
  { href: '/企業理念・行動指針/', label: '企業理念・行動指針' },
  { href: '/企業情報/', label: '会社概要' },
];

const social = [
  {
    href: 'https://x.com/SIADTJP0721',
    label: 'X',
    icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.725-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z',
  },
  {
    href: 'https://www.facebook.com/profile.php?id=61585306392063',
    label: 'Facebook',
    icon: 'M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H8v3h3v7h3v-7h3l1-3h-4V9c0-.6.4-1 1-1z',
  },
  {
    href: 'https://www.instagram.com/siadt.jp/',
    label: 'Instagram',
    icon: 'M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm10 2H7a3 3 0 00-3 3v10a3 3 0 003 3h10a3 3 0 003-3V7a3 3 0 00-3-3zm-5 3.5A4.5 4.5 0 1112 16.5 4.5 4.5 0 0112 7.5zm0 2A2.5 2.5 0 1014.5 12 2.5 2.5 0 0012 9.5zm5.25-3.25a1 1 0 11-1 1 1 1 0 011-1z',
  },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="SIA Digital Technology" />
    <meta property="og:locale" content={lang === 'zh-Hant' ? 'zh_TW' : 'ja_JP'} />
    <meta name="twitter:card" content="summary_large_image" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LQX050E2ZN"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-LQX050E2ZN');
    </script>
  </head>
  <body class="bg-white text-gray-800 antialiased">
    <header class="bg-ink text-white">
      <div class="border-b border-white/10">
        <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-2 px-4 py-2 text-xs text-gray-300">
          <div class="flex flex-wrap items-center gap-4">
            <a href="mailto:service@siadt.jp" class="hover:text-accent">service@siadt.jp</a>
            <a
              href="https://maps.app.goo.gl/y5sWWEem8hMMLE8r5"
              target="_blank"
              rel="noopener"
              class="hidden hover:text-accent sm:inline">大阪市住之江区南加賀屋3-8-26 YSビル6B</a
            >
          </div>
          <div class="flex items-center gap-3">
            {
              social.map((s) => (
                <a href={s.href} target="_blank" rel="noopener" class="text-gray-300 hover:text-accent" aria-label={s.label}>
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={s.icon} />
                  </svg>
                </a>
              ))
            }
          </div>
        </div>
      </div>
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
        <a href="/" class="flex shrink-0 items-center gap-2">
          <img src="/images/cropped-SIADT-白色LOGO-800x600-4.webp" alt="SIA Digital Technology" class="h-12 w-auto" width="96" height="72" />
        </a>
        <nav class="hidden items-center gap-6 text-sm lg:flex" aria-label="グローバルナビゲーション">
          <a href="/" class="py-2 hover:text-accent">home</a>
          <div class="group relative">
            <a href="/製品情報/" class="inline-flex items-center gap-1 py-2 hover:text-accent">
              製品情報
              <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5"/></svg>
            </a>
            <div class="invisible absolute left-0 top-full z-50 min-w-56 rounded-lg border border-white/10 bg-panel py-2 opacity-0 shadow-xl transition group-hover:visible group-hover:opacity-100">
              {navProducts.map((item) => (
                <a
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener' : undefined}
                  class="block px-4 py-2 hover:bg-white/5 hover:text-accent">{item.label}</a>
              ))}
            </div>
          </div>
          <a href="/ソリューション紹介/" class="py-2 hover:text-accent">サービス分野</a>
          <div class="group relative">
            <a href="/企業情報/" class="inline-flex items-center gap-1 py-2 hover:text-accent">
              企業情報
              <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5"/></svg>
            </a>
            <div class="invisible absolute left-0 top-full z-50 min-w-56 rounded-lg border border-white/10 bg-panel py-2 opacity-0 shadow-xl transition group-hover:visible group-hover:opacity-100">
              {navCompany.map((item) => (
                <a href={item.href} class="block px-4 py-2 hover:bg-white/5 hover:text-accent">{item.label}</a>
              ))}
            </div>
          </div>
          <a href="/連絡先/" class="py-2 hover:text-accent">連絡先</a>
          <a href="/eshop-2/" class="py-2 hover:text-accent">SHOP</a>
          <a href="/inquiries/" class="btn btn-accent !px-6 !py-2.5">お問い合わせ</a>
        </nav>
        <details class="relative lg:hidden">
          <summary class="flex cursor-pointer list-none items-center rounded border border-white/20 p-2" aria-label="メニュー">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </summary>
          <nav class="absolute right-0 top-full z-50 mt-2 w-64 rounded-lg border border-white/10 bg-panel py-2 text-sm shadow-xl" aria-label="モバイルナビゲーション">
            <a href="/" class="block px-4 py-2 hover:text-accent">home</a>
            <a href="/製品情報/" class="block px-4 py-2 hover:text-accent">製品情報</a>
            <a href="/ハードウェア製品/" class="block px-4 py-2 pl-8 hover:text-accent">AIエッジ計算製品</a>
            <a href="/人工知能アシスタント/" class="block px-4 py-2 pl-8 hover:text-accent">AIアシスタント</a>
            <a href="/ソリューション紹介/" class="block px-4 py-2 hover:text-accent">サービス分野</a>
            <a href="/企業理念・行動指針/" class="block px-4 py-2 hover:text-accent">企業理念・行動指針</a>
            <a href="/企業情報/" class="block px-4 py-2 hover:text-accent">会社概要</a>
            <a href="/連絡先/" class="block px-4 py-2 hover:text-accent">連絡先</a>
            <a href="/eshop-2/" class="block px-4 py-2 hover:text-accent">SHOP</a>
            <a href="/inquiries/" class="block px-4 py-2 text-accent">お問い合わせ</a>
          </nav>
        </details>
      </div>
    </header>

    <slot />

    <footer class="bg-ink text-gray-300">
      <div class="mx-auto max-w-6xl px-4 py-14">
        <div class="grid gap-10 lg:grid-cols-[1.4fr_repeat(4,minmax(0,1fr))]">
          <div>
            <a href="/" class="inline-flex items-center gap-2">
              <img src="/images/cropped-SIADT-白色LOGO-800x600-4.webp" alt="SIA Digital Technology" class="h-14 w-auto" width="112" height="84" loading="lazy" />
            </a>
            <p class="mt-4 text-sm leading-relaxed">日本の伝統を守り、日本の未来を創る</p>
            <div class="mt-5 flex items-center gap-4">
              {
                social.map((s) => (
                  <a href={s.href} target="_blank" rel="noopener" class="text-gray-400 hover:text-accent" aria-label={s.label}>
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d={s.icon} />
                    </svg>
                  </a>
                ))
              }
              <a href="https://note.com/siadt" target="_blank" rel="noopener" class="text-gray-400 hover:text-accent" aria-label="note">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M19.5 3h-15A1.5 1.5 0 003 4.5v15A1.5 1.5 0 004.5 21h15a1.5 1.5 0 001.5-1.5v-15A1.5 1.5 0 0019.5 3zM8 17H6V7h2v10zm5 0h-2V7h2v10zm5 0h-2V7h2v10z" />
                </svg>
              </a>
            </div>
          </div>
          <nav aria-label="Products">
            <h3 class="mb-4 text-xs font-bold uppercase tracking-wider text-white">Products</h3>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/ハードウェア製品/" class="hover:text-accent">AIエッジ計算製品</a></li>
              <li><a href="https://engawa-app.jp/" target="_blank" rel="noopener" class="hover:text-accent">個人向けAI製品</a></li>
              <li><a href="/shop/" class="hover:text-accent">小売店AIシステム</a></li>
              <li><a href="/car/" class="hover:text-accent">自動車AI分析システム</a></li>
            </ul>
          </nav>
          <nav aria-label="Service">
            <h3 class="mb-4 text-xs font-bold uppercase tracking-wider text-white">Service</h3>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/1631/uncategorized/" class="hover:text-accent">IT基盤サービス</a></li>
              <li><a href="/人工知能アシスタント/" class="hover:text-accent">AIアシスタント</a></li>
              <li><a href="/post/" class="hover:text-accent">FinTech技術サポート</a></li>
              <li><a href="/1256/uncategorized/" class="hover:text-accent">小売業界にDX支援</a></li>
            </ul>
          </nav>
          <nav aria-label="Resources">
            <h3 class="mb-4 text-xs font-bold uppercase tracking-wider text-white">Resources</h3>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/技術提携パートナー/" class="hover:text-accent">技術提携パートナー</a></li>
              <li><a href="/class/" class="hover:text-accent">AI技術トレーニング</a></li>
              <li><a href="/業務委託・営業パートナー募集/" class="hover:text-accent">営業パートナー募集</a></li>
              <li><a href="/採用情報/" class="hover:text-accent">採用情報</a></li>
            </ul>
          </nav>
          <nav aria-label="Support">
            <h3 class="mb-4 text-xs font-bold uppercase tracking-wider text-white">Support</h3>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/連絡先/" class="hover:text-accent">連絡先</a></li>
              <li><a href="/inquiries/" class="hover:text-accent">お問い合わせ</a></li>
              <li><a href="/利用規約（草案）/" class="hover:text-accent">利用規約</a></li>
              <li><a href="/特定商取引法に基づく表記/" class="hover:text-accent">特定商取引法表記</a></li>
              <li><a href="/プライバシーポリシー/" class="hover:text-accent">プライバシーポリシー</a></li>
              <li><a href="/privacy-policy/" class="hover:text-accent">暴力団等反社会勢力排除宣言</a></li>
            </ul>
          </nav>
        </div>
        <div class="mt-12 border-t border-white/10 pt-6 text-center text-xs text-gray-400">
          <p>ＳＩＡデジタルテクノロジー株式会社</p>
          <p class="mt-1">Copyright © 2022 · SIA Digital Technology · All rights reserved</p>
        </div>
      </div>
    </footer>
  </body>
</html>
