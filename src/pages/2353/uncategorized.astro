---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';

const pdf = '/files/2026年版：リテール＆モビリティ業界における次世代DX推進ガイド-〜AIエッジコンピューティングによる「ロス削減」と「収益最大化」の実現〜.pdf';
---

<Base title="【無料公開】（PDF）2026年版：リテール＆モビリティ業界における次世代DX推進ガイド「収益最大化」の実現 – SIA Digital Technology">
  <PageHero title="【無料公開】（PDF）2026年版：リテール＆モビリティ業界における次世代DX推進ガイド「収益最大化」の実現" />
  <main class="mx-auto max-w-4xl px-4 py-14">
    <div class="prose-body">
      <p>〜AIエッジコンピューティングによる「ロス削減」と「収益最大化」の実現〜</p>
      <object data={pdf} type="application/pdf" style="width:100%;height:600px" aria-label="2026年版：リテール＆モビリティ業界における次世代DX推進ガイド 〜AIエッジコンピューティングによる「ロス削減」と「収益最大化」の実現〜">
        <p>PDFを表示できない場合は、下のリンクからダウンロードしてください。</p>
      </object>
      <p class="mt-4">
        <a href={pdf}>2026年版：リテール＆モビリティ業界における次世代DX推進ガイド 〜AIエッジコンピューティングによる「ロス削減」と「収益最大化」の実現〜</a>
        <a href={pdf} download class="ml-4 inline-block rounded-lg bg-[#066aab] px-5 py-2 font-semibold text-white !no-underline">ダウンロード</a>
      </p>
    </div>
  </main>
</Base>
