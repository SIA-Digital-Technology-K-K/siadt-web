---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const products = [
  '小売業向けAI製品',
  '自動車向けAI製品',
  '個人的な製品',
  '人工知能アシスタント',
  '会社向けDX支援',
  'アプリケーションおよびシステム開発',
  'IT基盤サービス',
  '緣側app',
  '日本通',
  '他の',
];
---

<Base title="お問い合わせ(Inquiries) – SIA Digital Technology">
  <PageHero title="お問い合わせ(Inquiries)" />
  <main class="mx-auto max-w-2xl px-4 py-14">
    <form
      name="contact"
      method="POST"
      action="/thanks/"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      class="space-y-5"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden">
        <label>このフィールドには入力しないでください: <input name="bot-field" /></label>
      </p>
      <div>
        <label class="form-label" for="contact-name">お名前<span class="form-required" aria-hidden="true">*</span></label>
        <input class="form-input" type="text" id="contact-name" name="お名前" required maxlength="200" autocomplete="name" />
      </div>
      <div>
        <label class="form-label" for="contact-email">メールアドレス<span class="form-required" aria-hidden="true">*</span></label>
        <input class="form-input" type="email" id="contact-email" name="メールアドレス" required autocomplete="email" />
      </div>
      <div>
        <label class="form-label" for="contact-email2">メールアドレス (確認用)<span class="form-required" aria-hidden="true">*</span></label>
        <input class="form-input" type="email" id="contact-email2" name="メールアドレス確認用" required autocomplete="email" />
      </div>
      <div>
        <label class="form-label" for="contact-product">製品<span class="form-required" aria-hidden="true">*</span></label>
        <select class="form-input" id="contact-product" name="製品" required>
          <option value=""></option>
          {products.map((p) => <option value={p}>{p}</option>)}
        </select>
      </div>
      <div>
        <label class="form-label" for="contact-message">お問合せ内容<span class="form-required" aria-hidden="true">*</span></label>
        <textarea class="form-input" id="contact-message" name="お問合せ内容" rows="7" required maxlength="5000"></textarea>
      </div>
      <button type="submit" class="form-submit">確認</button>
    </form>
    <p class="mt-8 text-center text-sm text-gray-500">
      住所・電話番号は <a href="/連絡先/" class="text-[#0bbbb5] underline underline-offset-2">連絡先</a> をご覧ください。
    </p>
  </main>
</Base>
