---
interface Props {
  label?: string;
}
const { label = '無料相談' } = Astro.props;
---

<div class="my-12 flex justify-center">
  <a
    href="/inquiries/"
    class="inline-block rounded-xl bg-gradient-to-b from-[#005BAC] to-[#003F7D] px-8 py-3.5 font-semibold text-white shadow-lg shadow-[#005BAC]/25 transition hover:-translate-y-0.5 hover:shadow-xl"
    >{label}</a
  >
</div>
